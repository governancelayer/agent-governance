{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/governancelayer/agent-governance/blob/main/spec/dae-schema-v0.1.json",
  "title": "Delegated Authority Envelope v0.1",
  "type": "object",
  "required": [
    "delegation_id",
    "principal",
    "delegate",
    "allowed_actions",
    "constraints",
    "expiry",
    "revocable",
    "revoked",
    "audit_required"
  ],
  "additionalProperties": false,
  "properties": {
    "delegation_id": { "type": "string", "minLength": 1 },
    "principal": { "type": "string", "minLength": 1 },
    "delegate": { "type": "string", "minLength": 1 },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_value": { "type": "number" },
        "jurisdiction": { "type": "string", "minLength": 1 }
      }
    },
    "expiry": {
      "type": "string",
      "format": "date-time"
    },
    "revocable": { "type": "boolean" },
    "revoked": { "type": "boolean" },
    "audit_required": { "type": "boolean" }
  }
}
