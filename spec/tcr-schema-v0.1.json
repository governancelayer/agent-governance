{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/governancelayer/agent-governance/blob/main/spec/tcr-schema-v0.1.json",
  "title": "Transaction Commitment Record v0.1",
  "type": "object",
  "required": [
    "commitment_id",
    "transaction_id",
    "issuer",
    "counterparty",
    "commitments",
    "evidence_refs",
    "status",
    "audit_required"
  ],
  "additionalProperties": false,
  "properties": {
    "commitment_id": { "type": "string", "minLength": 1 },
    "transaction_id": { "type": "string", "minLength": 1 },
    "issuer": { "type": "string", "minLength": 1 },
    "counterparty": { "type": "string", "minLength": 1 },
    "commitments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "target", "fulfilled", "required"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "due_by": { "type": "string", "format": "date-time" },
          "fulfilled": { "type": "boolean" },
          "required": { "type": "boolean" }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "ref"],
        "additionalProperties": false,
        "properties": {
          "kind": { "type": "string", "minLength": 1 },
          "ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["pending", "fulfilled", "breached", "revoked"]
    },
    "breach_reason": { "type": "string", "minLength": 1 },
    "dispute_window_end": { "type": "string", "format": "date-time" },
    "audit_required": { "type": "boolean" }
  }
}
